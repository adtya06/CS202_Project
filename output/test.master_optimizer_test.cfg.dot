strict digraph {
start [label="start\nStart", shape=box];
end [label="end\nEnd", shape=box];
n1 [label="n1\nint a;\ndefs=['a']\nuses=[]", shape=box];
n2 [label="n2\nint b;\ndefs=['b']\nuses=[]", shape=box];
n3 [label="n3\nint c;\ndefs=['c']\nuses=[]", shape=box];
n4 [label="n4\nint d;\ndefs=['d']\nuses=[]", shape=box];
n5 [label="n5\nint e;\ndefs=['e']\nuses=[]", shape=box];
n6 [label="n6\nint dead_var;\ndefs=['dead_var']\nuses=[]", shape=box];
n7 [label="n7\na = 10;\ndefs=['a']\nuses=[]", shape=box];
n8 [label="n8\nb = 20 + (3 * a);\ndefs=['b']\nuses=['a']", shape=box];
n9 [label="n9\nc = a + b;\ndefs=['c']\nuses=['b', 'a']", shape=box];
n10 [label="n10\nfoo();\ndefs=[]\nuses=['foo']", shape=box];
n11 [label="n11\nd = c * 2;\ndefs=['d']\nuses=['c']", shape=box];
n12 [label="n12\ne = d / 2;\ndefs=['e']\nuses=['d']", shape=box];
n13 [label="n13\na = a * 2;\ndefs=['a']\nuses=['a']", shape=box];
n14 [label="n14\ndead_var = 999;\ndefs=['dead_var']\nuses=[]", shape=box];
n15 [label="n15\ndead_var = 888;\ndefs=['dead_var']\nuses=[]", shape=box];
n16 [label="n16\nif (a == 10)\ndefs=[]\nuses=['a']", shape=box];
n17 [label="n17\nprintf(\"%d\", &e);\ndefs=[]\nuses=['printf', 'e']", shape=box];
n18 [label="n18\nprintf(\"%d\", &a);\ndefs=[]\nuses=['printf', 'a']", shape=box];
n19 [label="n19\nreturn e;;\ndefs=[]\nuses=['e']", shape=box];
n20 [label="n20\nc = 0;\ndefs=['c']\nuses=[]", shape=box];
n21 [label="n21\nd = 0;\ndefs=['d']\nuses=[]", shape=box];
start -> n1;
n1 -> n2;
n2 -> n3;
n3 -> n4;
n4 -> n5;
n5 -> n6;
n6 -> n7;
n7 -> n8;
n8 -> n9;
n9 -> n10;
n10 -> n11;
n11 -> n12;
n12 -> n13;
n13 -> n14;
n14 -> n15;
n15 -> n16;
n16 -> n17 [label=T];
n16 -> n18 [label=F];
n17 -> n19;
n18 -> n19;
n19 -> end;
n20 -> n21;
n21 -> end;
}
