strict digraph {
start [label="start\nStart", shape=box];
end [label="end\nEnd", shape=box];
n1 [label="n1\nint x = 5 + 10;\ndefs=['x']\nuses=[]", shape=box];
n2 [label="n2\nint y = x;\ndefs=['y']\nuses=['x']", shape=box];
n3 [label="n3\nif (x)\ndefs=[]\nuses=['x']", shape=box];
n4 [label="n4\ny = y << 1;\ndefs=['y']\nuses=['y']", shape=box];
n5 [label="n5\nreturn y;;\ndefs=[]\nuses=['y']", shape=box];
start -> n1;
n1 -> n2;
n2 -> n3;
n3 -> n4 [label=T];
n3 -> n5 [label=F];
n4 -> n5;
n5 -> end;
}
